# Database
DATABASE_URL=postgresql://user:password@localhost:5432/popplate

# S3-compatible storage (MinIO on Coolify — set S3_FORCE_PATH_STYLE=true for MinIO)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=https://storage.popplate.dk
S3_REGION=us-east-1
S3_BUCKET=popplate-assets
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_FORCE_PATH_STYLE=true

# Auth
# Session encryption secret — must be at least 32 characters, keep secret
NUXT_SESSION_PASSWORD=change-me-in-production-at-least-32-chars

# Authentik / OIDC
AUTH_PROVIDER=authentik
AUTHENTIK_BASE_URL=https://auth.popplate.dk
NUXT_PUBLIC_AUTHENTIK_BASE_URL=https://auth.popplate.dk
AUTHENTIK_ISSUER=https://auth.popplate.dk/application/o/popplate/
AUTHENTIK_DISCOVERY_URL=https://auth.popplate.dk/application/o/popplate/.well-known/openid-configuration
AUTHENTIK_CLIENT_ID=popplate-web
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_PROVIDER_SLUG=popplate
AUTHENTIK_REDIRECT_URI=https://popplate.dk/api/auth/callback/authentik
AUTHENTIK_LOGOUT_REDIRECT_URI=https://popplate.dk/
AUTHENTIK_CLAIM_GROUPS=groups
AUTHENTIK_CLAIM_ROLES=roles
# Optional direct signup/enrollment link used by /platform/signup
# AUTHENTIK_SIGNUP_URL=https://auth.popplate.dk/if/flow/default-source-enrollment/

# Legacy custom admin login is deprecated once Authentik is enabled
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# 3D Generation service (MeshyAI)
MESHY_API_KEY=your-meshy-api-key

# Worker
# Set to 0 to disable the worker health server.
WORKER_HEALTH_PORT=3001

# Number of generation jobs to process in parallel. Runtime is capped at 3.
WORKER_CONCURRENCY=3

# App
NUXT_PUBLIC_APP_URL=https://popplate.dk
NUXT_PUBLIC_API_URL=https://api.popplate.dk
