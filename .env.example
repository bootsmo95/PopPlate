# Database
DATABASE_URL=postgresql://user:password@localhost:5432/popplate

# S3-compatible storage (MinIO on Coolify — set S3_FORCE_PATH_STYLE=true for MinIO)
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=popplate-assets
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_FORCE_PATH_STYLE=true

# Auth
# Session encryption secret — must be at least 32 characters, keep secret
NUXT_SESSION_PASSWORD=change-me-in-production-at-least-32-chars

# Authentik / OIDC
AUTH_PROVIDER=authentik
AUTHENTIK_BASE_URL=http://authentik.example.com
NUXT_PUBLIC_AUTHENTIK_BASE_URL=http://authentik.example.com
AUTHENTIK_ISSUER=http://authentik.example.com/application/o/popplate/
AUTHENTIK_DISCOVERY_URL=http://authentik.example.com/application/o/popplate/.well-known/openid-configuration
AUTHENTIK_CLIENT_ID=popplate-web
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_PROVIDER_SLUG=popplate
AUTHENTIK_REDIRECT_URI=https://your-app.example.com/api/auth/callback/authentik
AUTHENTIK_LOGOUT_REDIRECT_URI=https://your-app.example.com/
AUTHENTIK_CLAIM_GROUPS=groups
AUTHENTIK_CLAIM_ROLES=roles
# Optional direct signup/enrollment link used by /admin/signup
# AUTHENTIK_SIGNUP_URL=http://authentik.example.com/if/flow/default-enrollment-flow/

# Legacy custom admin login is deprecated once Authentik is enabled
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# 3D Generation service (MeshyAI)
MESHY_API_KEY=your-meshy-api-key

# App
NUXT_PUBLIC_APP_URL=http://localhost:3000
