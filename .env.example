# Database
DATABASE_URL=postgresql://user:password@localhost:5432/popplate

# S3-compatible storage
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=popplate-assets
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Auth
NUXT_SESSION_SECRET=change-me-in-production-at-least-32-chars

# 3D Generation service
GENERATION_API_URL=https://api.example.com
GENERATION_API_KEY=your-generation-api-key

# App
NUXT_PUBLIC_APP_URL=http://localhost:3000
