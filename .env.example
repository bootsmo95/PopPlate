# Database
DATABASE_URL=postgresql://user:password@localhost:5432/popplate

# S3-compatible storage (MinIO on Coolify — set S3_FORCE_PATH_STYLE=true for MinIO)
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=popplate-assets
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_FORCE_PATH_STYLE=true

# Auth
# Session encryption secret — must be at least 32 characters, keep secret
NUXT_SESSION_PASSWORD=change-me-in-production-at-least-32-chars

# Admin credentials (temporary until DB is wired in Task 3)
# Generate hash with: node -e "import('nuxt-auth-utils').then(m => m.hashPassword('yourpassword').then(console.log))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# 3D Generation service (MeshyAI)
MESHY_API_KEY=your-meshy-api-key

# App
NUXT_PUBLIC_APP_URL=http://localhost:3000
